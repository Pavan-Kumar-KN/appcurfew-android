<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp">

    <ImageView
        android:id="@+id/imageAppIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="App icon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textAppName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        app:layout_constraintEnd_toStartOf="@id/checkboxApp"
        app:layout_constraintStart_toEndOf="@id/imageAppIcon"
        app:layout_constraintTop_toTopOf="@id/imageAppIcon" />

    <TextView
        android:id="@+id/textAppPackage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textAppearance="?attr/textAppearanceBodySmall"
        app:layout_constraintEnd_toStartOf="@id/checkboxApp"
        app:layout_constraintStart_toEndOf="@id/imageAppIcon"
        app:layout_constraintTop_toBottomOf="@id/textAppName" />

    <CheckBox
        android:id="@+id/checkboxApp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>